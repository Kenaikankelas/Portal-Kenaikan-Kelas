<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pengumuman Kenaikan Kelas</title>
  <!-- Tailwind CSS CDN untuk desain responsif modern -->
  <script src=" https://script.google.com/macros/s/AKfycby5ke-N_7rE5fYcvTLyTVSCnTdPftnoEFqa0sbSbtA3Ryx_Zcc9b37yycMcLO7mzheK/exec"></script>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .custom-gradient {
      background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%);
    }
  </style>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col justify-between">

  <!-- Header Banner Sekolah -->
  <header class="custom-gradient text-white py-10 px-4 text-center shadow-lg relative overflow-hidden">
    <!-- Dekorasi Background -->
    <div class="absolute top-0 left-0 w-32 h-32 bg-blue-500 rounded-full mix-blend-multiply filter blur-xl opacity-20 transform -translate-x-10 -translate-y-10"></div>
    <div class="absolute bottom-0 right-0 w-40 h-40 bg-indigo-500 rounded-full mix-blend-multiply filter blur-xl opacity-20 transform translate-x-10 translate-y-10"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto">
      <div class="inline-flex items-center justify-center bg-white/10 p-3 rounded-2xl mb-4 backdrop-blur-sm border border-white/10">
        <!-- SVG Icon Toga Sekolah -->
        <svg class="w-10 h-10 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 14l9-5-9-5-9 5 9 5z"></path>
          <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path>
        </svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">Portal Pengumuman Hasil Belajar</h1>Tahun Ajaran 2025-2026
      <p class="text-blue-200 mt-2 text-sm md:text-base font-medium max-w-lg mx-auto">Masukkan NIS dan Password Anda untuk melihat hasil evaluasi kenaikan kelas secara aman.</p>
    </div>
  </header>

  <!-- Konten Utama -->
  <main class="flex-grow max-w-xl w-full mx-auto px-4 py-8">
    
    <!-- Formulir Pencarian Card -->
    <div class="bg-white rounded-3xl shadow-xl p-6 md:p-8 border border-slate-100 transition-all">
      <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
        <span class="w-2 h-6 bg-blue-600 rounded-full inline-block"></span>
        Formulir Verifikasi Siswa
      </h2>
      
      <form id="searchForm" onsubmit="handleSearch(event)" class="space-y-5">
        <!-- Input NIS -->
        <div>
          <label for="nis" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Nomor Induk Siswa (NIS)</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </span>
            <input type="text" id="nis" required placeholder="Contoh: 10459" 
              class="w-full pl-11 pr-4 py-3.5 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white text-slate-800 font-semibold transition-all">
          </div>
        </div>

        <!-- Input Password (Pass) -->
        <div>
          <label for="pass" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Password / PIN Pengaman</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </span>
            <input type="password" id="pass" required placeholder="Masukkan password Anda" 
              class="w-full pl-11 pr-4 py-3.5 bg-slate-50 border border-slate-200 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white text-slate-800 font-semibold transition-all">
          </div>
        </div>

        <!-- Tombol Cari -->
        <button type="submit" id="btnSubmit"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-6 rounded-2xl shadow-lg hover:shadow-blue-200 transition duration-300 transform active:scale-[0.98] flex justify-center items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          Cek Hasil Kelulusan
        </button>
      </form>
    </div>

    <!-- Alert Status Loader (Tersembunyi secara default) -->
    <div id="loader" class="hidden mt-6 text-center py-6 bg-white rounded-3xl border border-slate-100 shadow-md">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-blue-500 border-t-transparent mb-3"></div>
      <p class="text-slate-500 font-semibold text-sm">Menghubungkan ke database sekolah, mohon tunggu...</p>
    </div>

    <!-- Alert Error (Tersembunyi secara default) -->
    <div id="errorBox" class="hidden mt-6 bg-rose-50 border border-rose-200 text-rose-800 rounded-3xl p-5 flex items-start gap-3 shadow-sm">
      <svg class="w-6 h-6 text-rose-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
      <div>
        <h4 class="font-bold text-sm">Pencarian Gagal</h4>
        <p id="errorMessage" class="text-xs text-rose-600 mt-1 font-medium"></p>
      </div>
    </div>

    <!-- Tampilan Hasil Pencarian (Tersembunyi secara default) -->
    <div id="resultBox" class="hidden mt-8 bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-100 transform transition-all">
      <!-- Header Hasil -->
      <div class="p-6 bg-slate-50 border-b border-slate-100 flex justify-between items-center">
        <div>
          <span class="text-xs font-bold text-slate-400 uppercase tracking-wide">Hasil Pencarian</span>
          <h3 class="text-lg font-bold text-slate-800">Detail Evaluasi Siswa</h3>
        </div>
        <!-- Tombol Cetak / Reset -->
        <button onclick="resetForm()" class="text-xs font-semibold text-blue-600 hover:text-blue-800 bg-blue-50 hover:bg-blue-100 py-2 px-4 rounded-xl transition">
          Cari Lagi
        </button>
      </div>

      <!-- Detail Siswa -->
      <div class="p-6 md:p-8 space-y-6">
        <!-- Grid Data -->
        <div class="grid grid-cols-2 gap-4 border-b border-slate-100 pb-6">
          <div>
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Nama Lengkap</p>
            <p id="resNama" class="text-base font-bold text-slate-800 mt-0.5">-</p>
          </div>
          <div>
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">NIS</p>
            <p id="resNis" class="text-base font-semibold text-slate-700 mt-0.5">-</p>
          </div>
          <div class="col-span-2">
            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Kelas Saat Ini</p>
            <p id="resKelas" class="text-base font-semibold text-slate-700 mt-0.5">-</p>
          </div>
        </div>

        <!-- Box Status Kelulusan (Dynamic Highlight) -->
        <div id="statusBadge" class="p-5 rounded-2xl text-center transition-all duration-300">
          <p class="text-xs font-semibold uppercase tracking-widest opacity-85">Status Kenaikan Kelas</p>
          <p id="resKeterangan" class="text-2xl font-black mt-1 tracking-tight">-</p>
        </div>

        <!-- Box Pengumuman Detail -->
        <div class="bg-slate-50 rounded-2xl p-5 border border-slate-100">
          <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Pesan & Pengumuman Sekolah</p>
          <p id="resPengumuman" class="text-sm text-slate-600 leading-relaxed font-medium whitespace-pre-line">-</p>
        </div>
      </div>
    </div>

  </main>

  <!-- Footer -->
  <footer class="bg-slate-900 text-slate-400 text-center py-6 border-t border-slate-800 mt-12">
    <div class="max-w-md mx-auto px-4">
      <p class="text-xs font-semibold tracking-wide">© 2026 Portal Layanan Akademik Sekolah</p>
      <p class="text-[10px] text-slate-500 mt-1">Dibuat secara otomatis demi kemudahan akses wali murid dan siswa.</p>
    </div>
  </footer>

  <!-- Frontend Javascript -->
  <script>
    // Penanganan Event submit form
    function handleSearch(event) {
      event.preventDefault();

      const nisInput = document.getElementById('nis').value;
      const passInput = document.getElementById('pass').value;
      
      const btnSubmit = document.getElementById('btnSubmit');
      const loader = document.getElementById('loader');
      const errorBox = document.getElementById('errorBox');
      const resultBox = document.getElementById('resultBox');

      // Reset state UI
      errorBox.classList.add('hidden');
      resultBox.classList.add('hidden');
      loader.classList.remove('hidden');
      btnSubmit.disabled = true;

      // Memanggil fungsi server-side Google Apps Script 'cariSiswa(nis, pass)'
      google.script.run
        .withSuccessHandler(function(response) {
          loader.classList.add('hidden');
          btnSubmit.disabled = false;

          if (response.success) {
            // Isi data siswa ke template hasil
            document.getElementById('resNama').innerText = response.data.nama;
            document.getElementById('resNis').innerText = response.data.nis;
            document.getElementById('resKelas').innerText = response.data.kelas;
            document.getElementById('resKeterangan').innerText = response.data.keterangan;
            document.getElementById('resPengumuman').innerText = response.data.pengumuman || "Tidak ada pesan pengumuman tambahan.";

            // Logika Penyorotan Status (Highlighting)
            const statusBadge = document.getElementById('statusBadge');
            const statusText = response.data.keterangan.toUpperCase();

            // Atur gaya status berdasarkan teks keterangan
            if (statusText.includes("NAIK KELAS") || statusText.includes("LULUS") || statusText.includes("TUNTAS")) {
              // Status sukses (Hijau tebal)
              statusBadge.className = "p-5 rounded-2xl text-center bg-emerald-500 text-white shadow-md shadow-emerald-100 border border-emerald-400";
            } else if (statusText.includes("ADMINISTRASI") || statusText.includes("HUBUNGI") || statusText.includes("TERTUNDA")) {
              // Status bermasalah/administrasi (Kuning/Oranye)
              statusBadge.className = "p-5 rounded-2xl text-center bg-amber-500 text-white shadow-md shadow-amber-100 border border-amber-400";
            } else {
              // Status gagal atau lainnya (Merah)
              statusBadge.className = "p-5 rounded-2xl text-center bg-rose-600 text-white shadow-md shadow-rose-100 border border-rose-500";
            }

            // Tampilkan kotak hasil
            resultBox.classList.remove('hidden');
            resultBox.scrollIntoView({ behavior: 'smooth' });
          } else {
            // Tampilkan error
            document.getElementById('errorMessage').innerText = response.message;
            errorBox.classList.remove('hidden');
          }
        })
        .withFailureHandler(function(error) {
          loader.classList.add('hidden');
          btnSubmit.disabled = false;
          
          document.getElementById('errorMessage').innerText = "Koneksi ke server gagal atau terputus. Silakan coba beberapa saat lagi.";
          errorBox.classList.remove('hidden');
        })
        .cariSiswa(nisInput, passInput);
    }

    // Fungsi reset pencarian
    function resetForm() {
      document.getElementById('searchForm').reset();
      document.getElementById('resultBox').classList.add('hidden');
      document.getElementById('errorBox').classList.add('hidden');
      document.getElementById('nis').focus();
    }
  </script>
</body>
</html>

